# Fikir-Sepeti — ortam değişkenleri örneği
# Bu dosyayı `.env.local` olarak kopyala ve değerleri doldur.
# .env* dosyaları .gitignore'da — GERÇEK anahtarları asla commit etme.

# ── Supabase (ZORUNLU) ──
# Eksikse uygulama açılışta bilerek hata fırlatır (lib/supabase.ts).
# Supabase Dashboard → Project Settings → Data API / API Keys altından alınır.
NEXT_PUBLIC_SUPABASE_URL=https://<proje-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# ── Auth bypass (opsiyonel) ──
# "1" → Azure/Microsoft OAuth atlanır; kimlik localStorage'daki isim/e-postadan gelir.
# Yerel geliştirmede ve demo'da "1" kullanılır. Prod'da boş bırak veya "0" yap.
NEXT_PUBLIC_AUTH_BYPASS=1
